{
  "openapi" : "3.0.3",
  "info" : {
    "description" : "Read the [documentation wiki](https://github.com/realerikrani/project/wiki).",
    "title" : "Project API",
    "version" : "1.0.*"
  },
  "servers" : [ {
    "description" : "Local development server",
    "url" : "http://127.0.0.1:{port}",
    "variables" : {
      "port" : {
        "default" : "5000",
        "enum" : [ "3000", "5000", "8080" ]
      }
    }
  } ],
  "tags" : [ {
    "description" : "Things people work on",
    "name" : "projects"
  }, {
    "description" : "Public keys of projects",
    "name" : "keys"
  } ],
  "paths" : {
    "/projects" : {
      "delete" : {
        "responses" : {
          "200" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/_projects_get_200_response"
                }
              }
            },
            "description" : "Project deleted successfully"
          },
          "401" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Unauthorized"
          },
          "404" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Project not found"
          }
        },
        "security" : [ {
          "bearerAuth" : [ ]
        } ],
        "summary" : "Delete a project",
        "tags" : [ "projects" ]
      },
      "get" : {
        "responses" : {
          "200" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/_projects_get_200_response"
                }
              }
            },
            "description" : "Project retrieved successfully"
          },
          "401" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Unauthorized"
          },
          "404" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Project not found"
          }
        },
        "security" : [ {
          "bearerAuth" : [ ]
        } ],
        "summary" : "Read a project",
        "tags" : [ "projects" ]
      },
      "post" : {
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/_projects_post_request"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "201" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/_projects_post_201_response"
                }
              }
            },
            "description" : "Project created successfully"
          },
          "400" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Bad request"
          },
          "409" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "The public key is already registered"
          }
        },
        "summary" : "Create a new project with a public key",
        "tags" : [ "projects" ]
      }
    },
    "/keys" : {
      "get" : {
        "parameters" : [ {
          "description" : "The amount of keys to fetch at a time.\nEither page size or page token must be provided.\n",
          "explode" : true,
          "in" : "query",
          "name" : "page_size",
          "required" : false,
          "schema" : {
            "type" : "integer"
          },
          "style" : "form"
        }, {
          "description" : "The encoded info for loading next page of keys.\nEither page size or page token must be provided.\n",
          "explode" : true,
          "in" : "query",
          "name" : "page_token",
          "required" : false,
          "schema" : {
            "type" : "string"
          },
          "style" : "form"
        } ],
        "responses" : {
          "200" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/_keys_get_200_response"
                }
              }
            },
            "description" : "Keys retrieved successfully"
          },
          "401" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Unauthorized"
          },
          "400" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Bad request"
          }
        },
        "security" : [ {
          "bearerAuth" : [ ]
        } ],
        "summary" : "Read keys of the project",
        "tags" : [ "keys" ]
      },
      "post" : {
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/_keys_post_request"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "201" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/_keys_post_201_response"
                }
              }
            },
            "description" : "Key created successfully"
          },
          "400" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Bad request"
          },
          "401" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Unauthorized"
          },
          "404" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Project not found"
          },
          "409" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Key already exists"
          }
        },
        "security" : [ {
          "bearerAuth" : [ ]
        } ],
        "summary" : "Create a new key for a project",
        "tags" : [ "keys" ]
      }
    },
    "/keys/{id}" : {
      "delete" : {
        "parameters" : [ {
          "explode" : false,
          "in" : "path",
          "name" : "id",
          "required" : true,
          "schema" : {
            "format" : "uuid",
            "type" : "string"
          },
          "style" : "simple"
        } ],
        "responses" : {
          "200" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/_keys_post_201_response"
                }
              }
            },
            "description" : "Key deleted successfully"
          },
          "401" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Unauthorized"
          },
          "404" : {
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorGroup"
                }
              }
            },
            "description" : "Public key not found"
          }
        },
        "security" : [ {
          "bearerAuth" : [ ]
        } ],
        "summary" : "Delete a key",
        "tags" : [ "keys" ]
      }
    }
  },
  "components" : {
    "schemas" : {
      "Error" : {
        "properties" : {
          "message" : {
            "type" : "string"
          },
          "code" : {
            "type" : "string"
          }
        },
        "type" : "object"
      },
      "ErrorGroup" : {
        "properties" : {
          "status" : {
            "type" : "string"
          },
          "errors" : {
            "items" : {
              "$ref" : "#/components/schemas/Error"
            },
            "type" : "array"
          }
        },
        "type" : "object"
      },
      "Project" : {
        "properties" : {
          "id" : {
            "example" : "18c64064-b83e-45b6-ba68-ef681d06bb09",
            "format" : "uuid",
            "type" : "string"
          },
          "name" : {
            "example" : "Demo project name",
            "type" : "string"
          }
        },
        "type" : "object"
      },
      "_projects_get_200_response" : {
        "properties" : {
          "project" : {
            "$ref" : "#/components/schemas/Project"
          }
        },
        "type" : "object"
      },
      "_projects_post_request" : {
        "properties" : {
          "name" : {
            "example" : "Demo project name",
            "maxLength" : 100,
            "minLength" : 1,
            "type" : "string"
          },
          "public_key" : {
            "description" : "The public key in PEM format.",
            "example" : "-----BEGIN PUBLIC KEY-----\nMIICIjANBgkqhkiG9w0BAQEFAAOCAg8AMIICCgKCAgEArjs/EcBLWLXMB9PiOgal\nZMvP05T2zq6aksf+hQrZoSsVOeuIdr8JC6fbBrQeXKzfxSU39TdgLG16I4dgyMpP\nhwPpyapbU79mqZ6Edxi9WrqspUaks8A9s/BPiTN31nTOoFKydRHO6NXXPmkLHRgG\n3GFcEYr0KRT+Aj7LGPDZeFSC4zX5vBl6nUo1J4B0YNdu0CSO0JoUfjZ6YOaZngK1\n0JmiwxAcuR7CaouyfmML2b2qRP0qRckL/afxRXsUx5bdiw6swbVIt4W0K4/7Hjw7\nX30ALE3m1pnkfTd5nC2szPWZaAWVv+XRzHgwjtzdXQVw/sx3sHvjs7SuEd+uS/7C\nQxtMxEeS4EI2+d+w6jKRk1Cbv5abFp+gzngMzbmdOr3aIibT6QkqUgsz/9X0gQ7b\n92Gl7hPDgyGgZYoi3kJRuQsKCyEfJipe1g4QBMv+iYkR67l1geTjDPrnGQz5GSC+\nojcsFXecJtBFgU3Mw4LtvP7ZEwhn+DjMpQZ7RjenNxAep86CcyT/TdT1mRH1nCZo\n2IoCD9xcM0sgtWtxJeicxJ7qRjUvTrmTlSd2+kef0Ycb2kCwTB7iCrgIEhYdt2CF\nHfNBHMMVduJf/RTV0cPXf041cLyHYEzpZnrQ4FWcXLoBWjzGmiaT+TggiyEkro0j\nHR57xlAN43ucGD3PtjwJaOcCAwEAAQ==\n-----END PUBLIC KEY-----\n",
            "pattern" : "^-----BEGIN PUBLIC KEY-----[\\\\s\\\\S]*-----END PUBLIC KEY-----$",
            "type" : "string"
          }
        },
        "required" : [ "name", "public_key" ],
        "type" : "object"
      },
      "_projects_post_201_response" : {
        "properties" : {
          "kid" : {
            "description" : "The registered id of the public key",
            "example" : "721a0653-413a-4f88-9700-a12f1dea355f",
            "format" : "uuid",
            "type" : "string"
          },
          "project" : {
            "$ref" : "#/components/schemas/Project"
          }
        },
        "type" : "object"
      },
      "_keys_get_200_response_keys_inner" : {
        "properties" : {
          "created_at" : {
            "description" : "The timestamp when the key was created",
            "format" : "date-time",
            "type" : "string"
          },
          "id" : {
            "description" : "The unique identifier for the key",
            "format" : "uuid",
            "type" : "string"
          },
          "pem" : {
            "description" : "The public key in PEM format",
            "type" : "string"
          },
          "project_id" : {
            "description" : "The unique identifier for the project associated with the key",
            "format" : "uuid",
            "type" : "string"
          }
        },
        "type" : "object"
      },
      "_keys_get_200_response" : {
        "properties" : {
          "keys" : {
            "items" : {
              "$ref" : "#/components/schemas/_keys_get_200_response_keys_inner"
            },
            "type" : "array"
          },
          "next_page_token" : {
            "description" : "A token for the next page of results; null if no next page exists",
            "nullable" : true,
            "type" : "string"
          }
        },
        "type" : "object"
      },
      "_keys_post_request" : {
        "properties" : {
          "public_key" : {
            "type" : "string"
          }
        },
        "required" : [ "public_key" ],
        "type" : "object"
      },
      "_keys_post_201_response" : {
        "properties" : {
          "kid" : {
            "type" : "string"
          }
        },
        "type" : "object"
      }
    },
    "securitySchemes" : {
      "bearerAuth" : {
        "bearerFormat" : "JWT",
        "description" : "Use the\n[generated bearer value](https://github.com/realerikrani/project/wiki/How%E2%80%90to%E2%80%90guide:-Generate-Private-Key-JWT)\nfor authorization.\n",
        "scheme" : "bearer",
        "type" : "http"
      }
    }
  }
}